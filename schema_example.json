{
  "customer_id": {
    "required": true,
    "type": "int"
  },
  "email": {
    "required": true,
    "format": "email"
  },
  "phone": {
    "required": false,
    "format": "phone"
  },
  "signup_date": {
    "required": true,
    "type": "date"
  },
  "age": {
    "required": false,
    "type": "int",
    "min": 13,
    "max": 120
  },
  "plan": {
    "required": true,
    "allowed_values": ["free", "pro", "enterprise"]
  },
  "country_code": {
    "required": false,
    "pattern": "^[A-Z]{2}$"
  }
}
